DATABASE_URL=postgresql://talentsync:talentsync@localhost:5432/talentsync
# Generate a secure key using: openssl rand -hex 32
JWT_SECRET=your_super_secret_production_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
# Ollama LLM (Llama 3.2 — local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT=120
SBERT_MODEL_NAME=all-MiniLM-L6-v2

# Array of whitelisted domains for production and local dev
CORS_ORIGINS=["http://localhost:5173", "https://your-frontend-domain.vercel.app"]